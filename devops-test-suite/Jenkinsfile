// =============================================================================
// Jenkinsfile — DevOps Test Suite CI/CD Pipeline
// =============================================================================
//
//  Flow:
//    GitHub push → webhook → Jenkins → Build → Push DockerHub → Deploy on VM
//
//  No AKS / no az login needed.
//  Jenkins and the app run on the SAME VM — deploy is just docker compose up.
//
//  Prerequisites (one-time setup — see CICD-SETUP.md):
//    1. Jenkins credential ID "dockerhub-creds" with DockerHub username + password
//    2. Jenkins user added to the docker group
//    3. /opt/devops-app directory created and backend .env placed there
// =============================================================================

pipeline {

    agent any

    // ── Environment variables ──────────────────────────────────────────────────
    environment {
        // DockerHub image names
        DOCKERHUB_USER  = 'virendranawkar'
        BACKEND_IMAGE   = "${DOCKERHUB_USER}/devops-backend"
        FRONTEND_IMAGE  = "${DOCKERHUB_USER}/devops-frontend"

        // BUILD_NUMBER is auto-incremented by Jenkins: 1, 2, 3 …
        // We tag every image with it so you can always roll back to any exact build
        IMAGE_TAG       = "build-${BUILD_NUMBER}"

        // Jenkins credential (set up in Jenkins → Manage Credentials)
        // Exposes: DOCKERHUB_CREDS_USR (username) and DOCKERHUB_CREDS_PSW (password)
        DOCKERHUB_CREDS = credentials('dockerhub-creds')

        // Stable directory on the VM where the app runs permanently
        // Jenkins deploys HERE — it does NOT run the app from its own workspace
        DEPLOY_DIR      = '/opt/devops-app'
    }

    stages {

        // ── STAGE 1: Checkout ─────────────────────────────────────────────────
        // Pull the latest code from GitHub main branch into Jenkins workspace
        stage('Checkout') {
            steps {
                echo "=== Checking out source code ==="
                git branch: 'main',
                    url: 'https://github.com/Virendra-Nawkar/Devops-test.git'
                echo "✔ Code checked out — commit: ${GIT_COMMIT?.take(8)}"
            }
        }

        // ── STAGE 2: Test ─────────────────────────────────────────────────────
        // Run backend tests. If tests fail → pipeline stops here → broken code
        // never reaches DockerHub or gets deployed.
        stage('Test') {
            steps {
                echo "=== Running backend tests ==="
                dir('devops-test-suite/backend') {
                    sh 'npm install --quiet'
                    // '|| true' means: if no test script exists, skip gracefully
                    sh '''
                        if npm run test --if-present 2>/dev/null; then
                            echo "✔ Tests passed"
                        else
                            echo "⚠ No tests found — skipping"
                        fi
                    '''
                }
            }
        }

        // ── STAGE 3: Build Docker Images ──────────────────────────────────────
        // Build both images and tag them with:
        //   :build-42   → exact build number for rollback
        //   :latest     → always points to the newest build
        stage('Build') {
            steps {
                echo "=== Building Docker images (tag: ${IMAGE_TAG}) ==="
                dir('devops-test-suite') {
                    sh """
                        docker build \
                            -t ${BACKEND_IMAGE}:${IMAGE_TAG} \
                            -t ${BACKEND_IMAGE}:latest \
                            ./backend

                        docker build \
                            -t ${FRONTEND_IMAGE}:${IMAGE_TAG} \
                            -t ${FRONTEND_IMAGE}:latest \
                            ./frontend

                        echo "✔ Images built:"
                        echo "   ${BACKEND_IMAGE}:${IMAGE_TAG}"
                        echo "   ${FRONTEND_IMAGE}:${IMAGE_TAG}"
                    """
                }
            }
        }

        // ── STAGE 4: Push to DockerHub ────────────────────────────────────────
        // Push both images to DockerHub.
        // :build-42 → kept forever for rollback
        // :latest   → overwritten every build (what 'docker compose pull' fetches)
        stage('Push to DockerHub') {
            steps {
                echo "=== Pushing images to DockerHub ==="
                sh """
                    echo "${DOCKERHUB_CREDS_PSW}" | \
                        docker login -u "${DOCKERHUB_CREDS_USR}" --password-stdin

                    docker push ${BACKEND_IMAGE}:${IMAGE_TAG}
                    docker push ${BACKEND_IMAGE}:latest
                    docker push ${FRONTEND_IMAGE}:${IMAGE_TAG}
                    docker push ${FRONTEND_IMAGE}:latest

                    echo "✔ Pushed to DockerHub:"
                    echo "   hub.docker.com/r/${BACKEND_IMAGE}"
                    echo "   hub.docker.com/r/${FRONTEND_IMAGE}"
                """
            }
        }

        // ── STAGE 5: Deploy ───────────────────────────────────────────────────
        // Deploy on THIS VM using docker compose.
        // - Copies docker-compose.yml to the stable deploy directory
        // - Pulls the new :latest images from DockerHub
        // - Restarts containers (zero-downtime: new container starts before old stops)
        stage('Deploy') {
            steps {
                echo "=== Deploying build ${BUILD_NUMBER} to VM ==="
                sh """
                    # Ensure deploy directory exists
                    mkdir -p ${DEPLOY_DIR}

                    # Copy latest docker-compose.yml from repo to deploy dir
                    cp devops-test-suite/docker-compose.yml ${DEPLOY_DIR}/docker-compose.yml

                    # Pull the new :latest images we just pushed
                    cd ${DEPLOY_DIR}
                    BACKEND_IMAGE=${BACKEND_IMAGE}:latest \
                    FRONTEND_IMAGE=${FRONTEND_IMAGE}:latest \
                    docker compose pull

                    # Restart containers with the new images
                    # --force-recreate ensures containers restart even if config didn't change
                    BACKEND_IMAGE=${BACKEND_IMAGE}:latest \
                    FRONTEND_IMAGE=${FRONTEND_IMAGE}:latest \
                    docker compose up -d --force-recreate --remove-orphans

                    echo "✔ Containers restarted with build ${BUILD_NUMBER}"
                """
            }
        }

        // ── STAGE 6: Health Check ─────────────────────────────────────────────
        // Wait for containers to start, then hit both endpoints to confirm
        // the app is actually serving traffic.
        // If either fails → this stage fails → you know the deploy is broken.
        stage('Health Check') {
            steps {
                echo "=== Waiting for services to start ==="
                sh """
                    # Give containers 20 seconds to initialise
                    sleep 20

                    echo "Checking backend..."
                    curl --fail --silent --max-time 10 http://localhost:8081/api/ping \
                        && echo "✔ Backend is healthy" \
                        || (echo "✗ Backend health check FAILED" && exit 1)

                    echo "Checking frontend..."
                    curl --fail --silent --max-time 10 http://localhost:80 \
                        && echo "✔ Frontend is healthy" \
                        || (echo "✗ Frontend health check FAILED" && exit 1)

                    echo "✔ Both services are UP — build ${BUILD_NUMBER} is live"
                """
            }
        }

        // ── STAGE 7: Cleanup ──────────────────────────────────────────────────
        // Remove images from the Jenkins VM to free disk space.
        // We only delete the :latest and :build-N tags from local disk —
        // the images are safely stored on DockerHub for rollback.
        stage('Cleanup') {
            steps {
                echo "=== Cleaning up local images ==="
                sh """
                    docker rmi ${BACKEND_IMAGE}:${IMAGE_TAG}  || true
                    docker rmi ${FRONTEND_IMAGE}:${IMAGE_TAG} || true
                    docker rmi ${BACKEND_IMAGE}:latest        || true
                    docker rmi ${FRONTEND_IMAGE}:latest       || true

                    # Remove dangling (untagged) images and stopped containers
                    docker system prune -f

                    docker logout
                    echo "✔ Cleanup complete"
                """
                // Wipe the Jenkins workspace to free disk
                cleanWs()
            }
        }
    }

    // ── Post-build notifications ───────────────────────────────────────────────
    post {
        success {
            echo """
            ✅ ══════════════════════════════════════════
               BUILD ${BUILD_NUMBER} DEPLOYED SUCCESSFULLY
               Images: ${BACKEND_IMAGE}:${IMAGE_TAG}
                       ${FRONTEND_IMAGE}:${IMAGE_TAG}
            ══════════════════════════════════════════
            """
        }
        failure {
            echo """
            ❌ ══════════════════════════════════════════
               BUILD ${BUILD_NUMBER} FAILED
               Check the stage logs above to find the broken step.
               The previous version is still running unchanged.
            ══════════════════════════════════════════
            """
        }
        always {
            // Always log out of DockerHub even if pipeline fails mid-way
            sh 'docker logout || true'
        }
    }
}
