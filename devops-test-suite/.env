# =============================================================
# devops-test-suite — Master Configuration
# =============================================================
# Change VM_IP below if you deploy to a different server.
# This file is the single source of truth for all IPs and ports.
# =============================================================

# --- YOUR SERVER / VM IP ---
# Update this whenever you change your Linux VM or deploy elsewhere
VM_IP=20.12.224.28

# --- PORTS (match PORT RULES in the spec) ---
FRONTEND_PORT=80
BACKEND_PORT=8081

# --- BACKEND SETTINGS ---
# The backend binds to 0.0.0.0 so it is reachable from any IP
BACKEND_HOST=0.0.0.0
NODE_ENV=development

# --- CORS ---
# Allow requests from the VM IP (browser → backend)
# Add more comma-separated origins if needed
CORS_ORIGIN=http://20.12.224.28

# --- FILE UPLOAD ---
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# --- HISTORY ---
HISTORY_FILE=./scan-history.json
