# =============================================================
# Backend — local environment variables
# =============================================================
# Copy values from the root .env if you want to centralise them.
# The backend reads THIS file (backend/.env) on startup.
# =============================================================

PORT=8081
HOST=0.0.0.0
NODE_ENV=development

# Change to your VM IP so CORS lets the browser in
VM_IP=devops.virpages.com
CORS_ORIGIN=http://devops.virpages.com

MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads
HISTORY_FILE=./scan-history.json
